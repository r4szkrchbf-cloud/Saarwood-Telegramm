{
  "servers": {
    "wpcom-mcp": {
      "type": "http",
      "url": "https://public-api.wordpress.com/wpcom/v2/mcp/v1"
    },
    "hostinger-hosting": {
      "command": "npx",
      "args": [
        "--package=hostinger-api-mcp@latest",
        "hostinger-hosting-mcp"
      ]
    },
    "hostinger-domains": {
      "command": "npx",
      "args": [
        "--package=hostinger-api-mcp@latest",
        "hostinger-domains-mcp"
      ]
    },
    "hostinger-dns": {
      "command": "npx",
      "args": [
        "--package=hostinger-api-mcp@latest",
        "hostinger-dns-mcp"
      ]
    },
    "hostinger-vps": {
      "command": "npx",
      "args": [
        "--package=hostinger-api-mcp@latest",
        "hostinger-vps-mcp"
      ]
    }
  }
}
